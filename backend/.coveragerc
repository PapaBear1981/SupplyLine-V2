# Coverage.py configuration file
# https://coverage.readthedocs.io/

[run]
source = .
omit =
    */tests/*
    */test_*.py
    */__pycache__/*
    */venv/*
    */env/*
    */.venv/*
    */migrations/*
    */config.py
    */wsgi.py
    */setup.py
    # Feature-flagged modules — excluded from the main-CI coverage report so
    # the 70% gate isn't dragged down while these features are deactivated.
    # The nightly legacy-features job runs with FEATURE_KIT_MANAGEMENT=true and
    # FEATURE_REQUESTS=true and covers them.
    */routes_kit_reorders.py
    */routes_kit_transfers.py
    */routes_kit_messages.py
    */routes_master_kits.py
    */routes_user_requests.py
    */routes_orders.py
    */services/master_kit_service.py
    */utils/kit_fulfillment.py
    */utils/unified_requests.py

[report]
# Regexes for lines to exclude from consideration
exclude_lines =
    # Have to re-enable the standard pragma
    pragma: no cover

    # Don't complain about missing debug-only code:
    def __repr__
    if self\.debug

    # Don't complain if tests don't hit defensive assertion code:
    raise AssertionError
    raise NotImplementedError

    # Don't complain if non-runnable code isn't run:
    if 0:
    if __name__ == .__main__.:

    # Don't complain about abstract methods
    @(abc\.)?abstractmethod

ignore_errors = True
precision = 2
show_missing = True
skip_covered = False

[html]
directory = htmlcov
title = SupplyLine MRO Suite Coverage Report

[xml]
output = coverage.xml

[json]
output = coverage.json
pretty_print = True
